# ============================================
# Fishr - Variables de Entorno
# ============================================
# Copia este archivo a .env y ajusta los valores

# --- Sucursal (fishr-agent) ---
BRANCH_ID=
BRANCH_NAME=Mi Pescadería
BRANCH_RIF=J-00000000-0
BRANCH_ADDRESS=Dirección de la sucursal
BRANCH_PHONE=04121234567

# --- Sincronización ---
CENTRAL_URL=http://localhost:9090
SYNC_INTERVAL=300
SYNC_BATCH_SIZE=100
SYNC_RETRY_DELAY=60
SYNC_MAX_RETRIES=10

# --- Hardware ---
SCALE_PORT=/dev/ttyUSB0
PRINTER_PORT=/dev/usb/lp0

# --- Central (fishr-central) ---
DATABASE_URL=postgres://fishr:fishr@localhost:5432/fishr_central
